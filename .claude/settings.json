{
  "statusLine": {
    "type": "command",
    "command": "/home/arun/.claude/comamnds/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "permissions": {
    "allow": ["Bash(codex exec:*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/gate-askuserquestion.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/gate-mainloop-product-edits.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/self-audit.py"
          }
        ]
      }
    ]
  },
  "tui": "fullscreen",
  "theme": "dark",
  "agentPushNotifEnabled": true
}
